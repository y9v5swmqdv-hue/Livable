rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin emails
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'johann.hauenschild@gmail.com' ||
        request.auth.token.email == 'gabrielboos0@gmail.com'
      );
    }

    // Students can read/write their own profile. Admins can read/write all.
    match /students/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // Projects - any authenticated user can read/write (clients use anonymous auth)
    match /projects/{projectId} {
      allow read, write: if request.auth != null;
      allow create: if true; // clients can submit requests
    }

    // Conversations - participants or admins
    match /conversations/{convId} {
      allow read, write: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        isAdmin()
      );
      allow create: if request.auth != null;
    }

    match /conversations/{convId}/messages/{msgId} {
      allow read, write: if request.auth != null;
    }
  }
}
