rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'johann.hauenschild@gmail.com' ||
        request.auth.token.email == 'gabrielboos0@gmail.com'
      );
    }

    // Students can read/write their own profile. Admins can read/write all.
    match /students/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // Projects - allow public read by project ID (for checkout page)
    // Anyone can create (client submitting request)
    // Only authenticated users or admins can update
    match /projects/{projectId} {
      allow read:   if true;
      allow create: if true;
      allow update: if request.auth != null || isAdmin();
    }

    // Conversations - participants or admins can read/write
    match /conversations/{convId} {
      allow read, write: if request.auth != null;
      allow create:      if request.auth != null;
    }

    match /conversations/{convId}/messages/{msgId} {
      allow read, write: if request.auth != null;
    }
  }
}
